# ============================================================
# PESCP — Plataforma Estadual de Sustentabilidade em
#          Contratações Públicas
# Arquivo de exemplo. Copie para .env e ajuste valores.
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=pescp.settings.dev
DJANGO_SECRET_KEY=changeme-generate-a-real-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres — banco isolado, NÃO compartilhado com a BDLP.
# Porta de host 5433 para coexistir com a BDLP (que usa 5432) — convenção LILP.
POSTGRES_DB=pescp
POSTGRES_USER=pescp
POSTGRES_PASSWORD=changeme_pescp_2026
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# Porta exposta no host pelo container do portal.
# 8002 para coexistir com a BDLP (portal 8000, nourau 8080) — convenção LILP.
PESCP_PORT=8002

# URL pública (para canonical URLs em PDFs/DOCX)
PESCP_PUBLIC_URL=http://localhost:8002

# Contato institucional exibido em aviso de versão e rodapé
PESCP_CONTATO_EMAIL=lab.sggd@sp.gov.br
